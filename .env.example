# =============================================================================
# Archon Treasury — Environment Variables
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:***@localhost:5432/archon_treasury"

# Pool settings (optional — safe defaults applied if unset)
# DATABASE_POOL_MIN=0
# DATABASE_POOL_MAX=10
# DATABASE_IDLE_TIMEOUT_MS=10000
# DATABASE_CONNECTION_TIMEOUT_MS=5000

# TLS mode for PostgreSQL connection
# "disable" — no TLS (default, safe for local development)
# "require" — encrypted connection (required for production managed PostgreSQL)
# NOTE: "require" uses rejectUnauthorized: false (no server certificate verification).
# Production-grade verified TLS requires additional CA configuration — see README.
# DATABASE_SSL_MODE="disable"

# ── Auth ─────────────────────────────────────────────────────────────────────
# OIDC provider (e.g. Auth0, Clerk, NextAuth)
AUTH_SECRET=""
AUTH_OIDC_ISSUER=""
AUTH_OIDC_CLIENT_ID=""
AUTH_OIDC_CLIENT_SECRET=""

# ── Circle ───────────────────────────────────────────────────────────────────
# Circle API key (for DCW operations)
CIRCLE_API_KEY=""
# Circle entity secret (for DCW signing)
CIRCLE_ENTITY_SECRET=""
# Circle wallet set ID (per environment)
CIRCLE_WALLET_SET_ID=""

# ── Circle CLI (Agent Wallet) ────────────────────────────────────────────────
# Circle CLI binary path
CIRCLE_CLI_PATH="circle"
# Circle CLI session token (refreshed via `circle auth login`)
CIRCLE_SESSION_TOKEN=""

# ── Gateway ──────────────────────────────────────────────────────────────────
# Circle Gateway API key
GATEWAY_API_KEY=""
# Gateway wallet address (for deposits)
GATEWAY_WALLET_ADDRESS=""

# ── x402 ─────────────────────────────────────────────────────────────────────
# x402 payment facilitator endpoint
X402_FACILITATOR_URL=""

# ── Hermes Agent ─────────────────────────────────────────────────────────────
# Hermes MCP server endpoint (private network)
HERMES_MCP_URL="http://localhost:3001"
# Hermes API key (for MCP auth)
HERMES_API_KEY=""

# ── Chain RPCs ───────────────────────────────────────────────────────────────
ARC_TESTNET_RPC_URL=""
ETHEREUM_SEPOLIA_RPC_URL=""
BASE_SEPOLIA_RPC_URL=""

# ── Observability ────────────────────────────────────────────────────────────
# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="archon-treasury"

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
LOG_LEVEL="info"
